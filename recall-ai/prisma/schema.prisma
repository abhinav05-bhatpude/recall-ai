generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  image     String?

  folders   Folder[]
  notes     Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Folder {
  id          String   @id @default(cuid())
  name        String

  userId      String
  user        User @relation(fields: [userId], references: [id])

  notes       Note[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}